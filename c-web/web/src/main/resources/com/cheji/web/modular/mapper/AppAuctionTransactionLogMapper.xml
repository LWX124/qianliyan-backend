<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cheji.web.modular.mapper.AppAuctionTransactionLogMapper">

    <select id="selectByUserAndType" resultType="AppAuctionTransactionLogEntity">
        SELECT t1.* FROM app_auction_transaction_log t1
        where 1=1
        <if test="userId != null and userId != ''">
            AND t1.user_id =#{userId}
        </if>
        <if test="queryType != null and queryType == 1">
            AND t1.car_id is null
        </if>
        <if test="queryType != null and queryType == 2">
            and t1.car_id is not null
        </if>
        order by t1.create_time desc
        <if test="offset != null  and limit != null ">
            LIMIT #{offset},#{limit}
        </if>
    </select>


</mapper>
