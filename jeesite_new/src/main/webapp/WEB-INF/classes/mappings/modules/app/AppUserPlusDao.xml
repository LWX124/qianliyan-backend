<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppUserPlusDao">
	
	<!-- 查询数据
	<select id="findList" resultType="AppUserPlus">
		SELECT ${sqlMap.column.toSql()}
		FROM ${sqlMap.table.toSql()}
		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->

	<!--AppUserPlus findPlusUserByUserId(Integer parentId);-->
	<select id="findPlusUserByUserId" resultType="AppUserPlus">
		SELECT * FROM app_user_plus WHERE user_id = #{parentId} ORDER BY create_time DESC LIMIT 0,1
	</select>

	<insert id="insertSelf" parameterType="AppUserPlus">
		insert into app_user_plus (create_time,user_id,invalid_time_start,invalid_time_end,invite_code)
		value (#{createTime},#{userId},#{invalidTimeStart},#{invalidTimeEnd},#{inviteCode})
	</insert>
</mapper>