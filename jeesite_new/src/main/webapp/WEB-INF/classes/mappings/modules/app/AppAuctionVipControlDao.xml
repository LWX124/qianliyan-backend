<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppAuctionVipControlDao">
	
	<!-- 查询数据
	<select id="findList" resultType="AppAuctionVipControl">
		SELECT ${sqlMap.column.toSql()}
		FROM ${sqlMap.table.toSql()}
		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->
	<select id="getByUserId" resultType="AppAuctionVipControl">
		SELECT *
		FROM app_auction_vip_control
		where user_id = #{userId}
         and state=1
        order by create_time desc  limit 1
	</select>

	<select id="getVips" resultType="AppAuctionVipControl">
		SELECT *
		FROM app_auction_vip_control
	</select>
</mapper>