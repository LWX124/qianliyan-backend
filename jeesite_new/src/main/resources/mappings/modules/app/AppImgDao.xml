<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppImgDao">
	
	<!-- 查询数据
	<select id="findList" resultType="AppImg">
		SELECT ${sqlMap.column.toSql()}
		FROM ${sqlMap.table.toSql()}
		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->
	<select id="findImg" resultType="AppImg">
		SELECT * FROM app_img WHERE type = #{type,jdbcType=INTEGER} AND key_id = #{id,jdbcType=BIGINT};
	</select>

<!--	List<Integer> findAllImg(String id);-->
	<select id="findAllImg" resultType="Integer">
		SELECT * FROM app_img WHERE type = 3 AND key_id = #{id}
	</select>

<!--	  void insertNew(AppImg appImg);-->
	<insert id="insertNew">
        insert into app_img (key_id,url,type,`index`,creat_time,update_time)
		value (#{keyId},#{url},#{type},#{index},#{creatTime},#{updateTime})
	</insert>
</mapper>