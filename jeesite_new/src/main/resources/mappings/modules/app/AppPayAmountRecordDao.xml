<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppPayAmountRecordDao">
	
	<!-- 查询数据
	<select id="findList" resultType="AppPayAmountRecord">
		SELECT ${sqlMap.column.toSql()}
		FROM ${sqlMap.table.toSql()}
		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->

	<!--List<AppPayAmountRecord> findRecord(String id, String userId);-->
	<select id="findRecord" resultType="AppPayAmountRecord">
		SELECT * FROM  app_pay_amount_record WHERE accid =#{id} AND user_id = #{userId} AND type =1
	</select>


<!--	BigDecimal findAllPayAmount(String id);-->
	<select id="findAllPayAmount" resultType="BigDecimal">
		SELECT SUM(pay_amount) FROM app_pay_amount_record WHERE accid = #{id}
	</select>



</mapper>