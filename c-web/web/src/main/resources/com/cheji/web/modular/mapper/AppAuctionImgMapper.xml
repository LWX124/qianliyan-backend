<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cheji.web.modular.mapper.AppAuctionImgMapper">

    <select id="selectByCarId" resultType="AppAuctionImgEntity">
        SELECT a.url, a.car_id, a.id, a.index, a.state FROM app_auction_img a
        WHERE  a.car_id = #{car_id}
    </select>

    <select id="findImgByRepair" resultType="java.lang.String">


        SELECT url FROM app_auction_img WHERE car_id = #{carId} AND state = 10 AND `index` = 1

        ORDER BY state asc LIMIT 1

    </select>
