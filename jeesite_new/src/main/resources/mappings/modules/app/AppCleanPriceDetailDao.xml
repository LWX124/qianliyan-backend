	<!--List<AppCleanPriceDetail> finduserB(String userBId);-->
	<select id="finduserB" resultType="AppCleanPriceDetail">
		SELECT * FROM app_clean_price_detail WHERE user_b_id = #{userBId}
	</select>

<!--	AppCleanPriceDetail findProject(Integer userBId, Integer carType, Integer cleanType);-->
	<select id="findProject" resultType="AppCleanPriceDetail">
		SELECT * FROM app_clean_price_detail WHERE user_b_id = #{userBId} AND clean_type = #{carType} AND car_type = #{cleanType}
	</select>

	<select id="selectForUpdate" resultType="AppCleanPriceDetail">
		   select * from app_clean_price_detail t1
        where t1.id=#{bussinessId} for update
	</select>
