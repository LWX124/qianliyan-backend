<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cheji.web.modular.mapper.CityMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.cheji.web.modular.domain.CityEntity">
        <id column="id" property="id" />
        <result column="city_name" property="cityName" />
        <result column="adcode" property="adcode" />
        <result column="citycode" property="citycode" />
        <result column="recommend_city" property="recommendCity" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, city_name AS cityName, adcode, citycode, recommend_city AS recommendCity
    </sql>

</mapper>
