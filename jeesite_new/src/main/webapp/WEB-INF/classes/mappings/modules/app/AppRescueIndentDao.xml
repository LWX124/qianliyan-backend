<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppRescueIndentDao">

	<!-- 查询数据
	<select id="findList" resultType="AppRescueIndent">
		SELECT ${sqlMap.column.toSql()}
		FROM ${sqlMap.table.toSql()}
		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->

	<select id="selectByOutTradeNo" parameterType="string" resultType="com.jeesite.modules.app.entity.AppRescueIndent">
		select * from app_rescue_indent t1
		where t1.merchants_pay_number=#{outTradeNo}
	</select>

<!--	AppRescueIndent findRescueByOrder(String rescueNumber);-->
	<select id="findRescueByOrder" resultType="AppRescueIndent">
		SELECT * FROM app_rescue_indent
		 	WHERE rescue_number = #{rescueNumber}
	</select>


<!--	List<AppRescueIndent> findOverThreeIndent();-->
	<select id="findOverThreeIndent" resultType="AppRescueIndent">
		SELECT * FROM app_rescue_indent where TIMESTAMPDIFF(MINUTE,create_time,NOW())>4320 AND state = 2
	</select>
</mapper>
