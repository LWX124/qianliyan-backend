		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->


<!--	List<EmployeeClaim> findClaimAdjusters();-->
	<select id="findNowClaimAdjusters" resultType="AppUser">
		SELECT b.id parentId,a.username username,b.username phoneNumber FROM app_employee as a
		LEFT JOIN app_user as b  on a.user_id = b.id WHERE b.username &lt;&gt; ''
	</select>

<!--	void addSendSheet();-->
	<insert id="addSendSheet" useGeneratedKeys="true" keyProperty="id">
		insert into app_send_out_sheet (user_b_id,adress,remark,lng,lat,state,create_time,update_time)
		value (#{userBId},#{adress},#{remark},#{lng},#{lat},#{state},#{createTime},#{updateTime})
	</insert>


<!--	Integer findSendUserbid(Integer id);-->
	<select id="findSendUserbid" resultType="Integer">
		SELECT a.id FROM app_b_user as a
			LEFT JOIN app_user as b on a.username = b.username
   			LEFT JOIN app_employee as c ON c.user_id = b.id WHERE c.user_id = #{id}

	</select>

<!--	String findByLngLat(String lat, String lng);-->

	<select id="findByLngLat" resultType="String">
		SELECT id FROM app_send_out_sheet WHERE create_time = #{lng} AND user_b_id = #{lat}
	</select>

<!--	List<String> findCheckImg(String indentId);-->
	<select id="findCheckImg" resultType="String">
		SELECT url FROM app_send_url WHERE send_id = #{indentId}   and `type` = 2
	</select>



</mapper>


