<!--	void insertCus(AppBusinessConfirm appBusinessConfirm);-->
	<insert id="insertCus">

		insert into app_business_confirm (user_b_id,business_confirm,accident_reponsibility,customers_have,not_united_customer,charter_shop,create_time,update_time)
		value (#{userBId},#{businessConfirm},#{accidentReponsibility},#{customersHave},#{notUnitedCustomer},#{charterShop},#{createTime},#{updateTime})
	</insert>

<!--	List<AppBusinessConfirm> selectByUserBId(String userBId);-->
	<select id="selectByUserBId" resultType="AppBusinessConfirm">
		SELECT * FROM app_business_confirm WHERE user_b_id = #{userBId}
	</select>

</mapper>
