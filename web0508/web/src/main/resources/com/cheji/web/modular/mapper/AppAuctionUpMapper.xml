<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cheji.web.modular.mapper.AppAuctionUpMapper">


    <!--  List<AppAuctionEntity> todayNew(); -->

    <select id="todayNew" resultMap="AppAuctionEntityMap">
        select a.*,
               i.id iId, i.car_id iCarId, i.state iState, i.url iUrl, i.index iIndex
        from app_auction a
                 left join app_auction_up u on a.id = u.car_id
                 left join app_auction_img i on u.car_id = i.car_id
        <where>
            TO_DAYS(u.begin_time) = TO_DAYS(NOW())
                and a.up_state = 1
                and a.car_state in (3,7)
                and i.index = 1

            <if test="ac.brand != null and ac.brand !=''">
                AND a.brand like CONCAT('%',#{ac.brand},'%')
            </if>

            <if test="ac.auctionState != null and ac.auctionState == 1">
                AND a.car_state=7
                and u.begin_time &lt; now()
                and u.end_time > now()
            </if>
            <if test="ac.auctionState != null and ac.auctionState == 2">
                and u.begin_time &lt; now()
            </if>

            <if test="ac.fixedPrice != null and ac.fixedPrice !=''">
                AND a.fixed_price = #{ac.fixedPrice}
            </if>

            <if test="ac.parkingPlace != null and ac.parkingPlace != ''">
                AND a.parking_place like CONCAT('%',#{ac.parkingPlace},'%')
            </if>

            <if test="ac.accType != null and ac.accType != ''">
                AND a.accident_type = #{ac.accType}
            </if>

            <if test="ac.priceMin != null and ac.priceMax != null and ac.priceMin != '' and ac.priceMax != ''">
                AND a.price between #{ac.priceMin} and #{ac.priceMax}
            </if>

        </where>

        order by a.create_time  DESC

        limit #{page},20

    </select>


    <select id="todayNewCount" resultType="java.lang.Integer">
        select count(1)
        from app_auction a
        left join app_auction_up u on a.id = u.car_id
        left join app_auction_img i on u.car_id = i.car_id
        <where>
            TO_DAYS(u.begin_time) = TO_DAYS(NOW())
            and a.up_state = 1
            and a.car_state in (3,7)
            and i.index = 1

            <if test="ac.brand != null and ac.brand !=''">
                AND a.brand like CONCAT('%',#{ac.brand},'%')
            </if>
            <if test="ac.auctionState != null and ac.auctionState == 1">
                AND a.car_state=7
                and u.begin_time &lt; now()
                and u.end_time > now()
            </if>
            <if test="ac.auctionState != null and ac.auctionState == 2">
                and u.begin_time > now()
            </if>

            <if test="ac.parkingPlace != null and ac.parkingPlace != ''">
                AND a.parking_place like CONCAT('%',#{ac.parkingPlace},'%')
            </if>

            <if test="ac.accType != null and ac.accType != ''">
                AND a.accident_type = #{ac.accType}
            </if>

            <if test="ac.priceMin != null and ac.priceMax != null and ac.priceMin != '' and ac.priceMax != ''">
                AND a.price between #{ac.priceMin} and #{ac.priceMax}
            </if>

        </where>


    </select>



