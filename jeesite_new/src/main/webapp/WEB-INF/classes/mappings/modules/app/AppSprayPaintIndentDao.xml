<!--	List<String> findImgs(String sprayId);-->
	<select id="findImgs" resultType="String">
		SELECT url FROM app_spray_paint_img WHERE spray_paint_id = #{sprayId} AND type = #{type}
	</select>


<!--	AppSprayPaintIndent findByNumber(String rescueNumber);-->
	<select id="findByNumber" resultType="AppSprayPaintIndent">
		select * from app_spray_paint_indent where spray_paint_number = #{rescueNumber}
	</select>
