<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cheji.web.modular.mapper.LeagueMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.cheji.web.modular.domain.LeagueEntity">
        <id column="id" property="id" />
        <result column="shop_name" property="shopName" />
        <result column="brand" property="brand" />
        <result column="address" property="address" />
        <result column="name" property="name" />
        <result column="phone_number" property="phoneNumber" />
        <result column="city_name" property="cityName" />
        <result column="creat_time" property="creatTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, shop_name AS shopName, brand, address, name, phone_number AS phoneNumber, city_name AS cityName, creat_time AS creatTime, update_time AS updateTime
    </sql>

</mapper>
