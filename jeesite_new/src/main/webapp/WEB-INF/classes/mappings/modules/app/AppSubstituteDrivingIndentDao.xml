<!--	AppYearCheckIndent findBySubDri(String subDriNumber);-->
	<select id="findBySubDri" resultType="AppSubstituteDrivingIndent">
		SELECT * FROM app_substitute_driving_indent WHERE substitute_driving_number = #{subDriNumber}
	</select>


<!--	List<AppSubstituteDrivingIndent> findNoCondirmIndent();-->
	<select id="findNoCondirmIndent" resultType="AppSubstituteDrivingIndent">
		select * from app_substitute_driving_indent where now() >SUBDATE(create_time,interval -2 day) AND indent_state = 5
	</select>

</mapper>