<!--	void insertNewCon(AppBUserContract appBUserContract);-->
	<insert id="insertNewCon">
		insert into app_b_user_contract (url,`index`,user_b_id,state,create_time,update_time)
		value (#{url},#{index},#{userBId},#{state},#{createTime},#{updateTime})
	</insert>

<!--	String selectUrl(String newUrl);-->
	<select id="selectUrl" resultType="String">
		select id from app_b_user_contract where url = #{newUrl}
	</select>

<!--	List<AppBUserContract> selectAll(String id);-->
	<select id="selectAll" resultType="AppBUserContract">
		SELECT * FROM app_b_user_contract WHERE user_b_id = #{id}
	</select>

</mapper>