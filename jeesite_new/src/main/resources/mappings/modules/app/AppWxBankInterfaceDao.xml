<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppWxBankInterfaceDao">

    <!-- 查询数据
    <select id="findList" resultType="AppWxBankInterface">
        SELECT ${sqlMap.column.toSql()}
        FROM ${sqlMap.table.toSql()}
        <where>
            ${sqlMap.where.toSql()}
        </where>
        ORDER BY ${sqlMap.order.toSql()}
    </select> -->

    <select id="selectForFail" resultType="AppWxBankInterface">
		select * from app_wx_bank_interface t1
		where t1.result_code='FAIL' and t1.ops_flag=1
	</select>

    <update id="updateStatusByTradeNo" parameterType="string">
		update app_wx_bank_interface t1 set  t1.ops_flag=2 where partner_trade_no=#{partnerTradeNo}
	</update>
</mapper>