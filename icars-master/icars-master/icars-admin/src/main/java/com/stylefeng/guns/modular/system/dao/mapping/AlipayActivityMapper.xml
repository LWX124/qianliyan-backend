<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.stylefeng.guns.modular.system.dao.AlipayActivityMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.stylefeng.guns.modular.system.model.AlipayActivity">
        <id column="id" property="id" />
        <result column="crowd_no" property="crowdNo" />
        <result column="pay_url" property="payUrl" />
        <result column="origin_crowd_no" property="originCrowdNo" />
        <result column="createTime" property="createTime" />
        <result column="startTime" property="startTime" />
        <result column="endTime" property="endTime" />
    </resultMap>
    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, crowd_no, pay_url, origin_crowd_no, createTime, startTime, endTime
    </sql>
    <sql id="Biz_Column_List">
        id, crowd_no as crowdNo, pay_url as payUrl, origin_crowd_no as originCrowdNo, createTime, startTime, endTime
    </sql>
    <select id="selectListForPage" resultType="map">
        select
        <include refid="Base_Column_List" />
        from biz_alipay_activity
        <where>
            <if test="startTime != null and startTime != '' and endTime != '' and endTime != null">
                and (startTime between CONCAT(#{startTime},' 00:00:00') and CONCAT(#{endTime},' 00:00:00'))
            </if>
        </where>
        ORDER BY createTime desc
    </select>
    <select id="selectMaxNew" resultType="com.stylefeng.guns.modular.system.model.AlipayActivity">
        select
        <include refid="Biz_Column_List" />
        from biz_alipay_activity
        ORDER BY createTime desc limit 1
    </select>
</mapper>