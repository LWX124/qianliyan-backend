<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesite.modules.app.dao.AppMerchantsLableDao">
	
	<!-- 查询数据
	<select id="findList" resultType="AppMerchantsLable">
		SELECT ${sqlMap.column.toSql()}
		FROM ${sqlMap.table.toSql()}
		<where>
			${sqlMap.where.toSql()}
		</where>
		ORDER BY ${sqlMap.order.toSql()}
	</select> -->

	<select id="selectBylable" resultType="AppMerchantsLable">
		SELECT * FROM app_merchants_lable WHERE merchants_id = #{merchantsId,jdbcType=INTEGER} and lable_id = #{lableId,jdbcType=INTEGER}
	</select>


</mapper>