            <result column="iIndex" property="index"/>
            <result column="iCarId" property="carId"/>
            <result column="iState" property="state"/>
        </collection>
    </resultMap>

    <select id="todayNewCount" resultType="Integer">
        select count(a.id) from app_auction a left join app_auction_up u on a.id = u.car_id
        where TO_DAYS(u.begin_time) = TO_DAYS(NOW())
          and a.up_state = 1
          and a.car_state in (3,7)
    </select>
</mapper>
